        <entryLink id="c6c4-949d-5617-3753" name="Weeping Blade" hidden="false" collective="false" import="true" targetId="abdc-e9b8-58f7-24af" type="selectionEntry" />
        <entryLink id="cba6-f414-785a-1b69" name="Cursed Blade of Delirium" hidden="false" collective="false" import="true" targetId="66df-1318-0e87-c602" type="selectionEntry" />
        <entryLink id="e077-24c8-bd14-acba" name="Headsplitter" hidden="false" collective="false" import="true" targetId="a06a-e2d1-78bc-96b7" type="selectionEntry" />
